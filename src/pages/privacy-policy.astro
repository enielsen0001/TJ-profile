---
import '../styles/global.css';
import privacyContent from '../data/privacy.json';
import Layout from '../layouts/Layout.astro';
---

<Layout title={`${privacyContent.title} · Tiffany Jones`} description="Privacy policy disclosures for Tiffany Jones financial consulting site.">
  <main class="max-w-2xl mx-auto px-6 py-16 md:py-24">
      <a href="/" class="text-sm font-medium text-accent hover:underline inline-flex items-center gap-1 mb-8">
        ← Back to Home
      </a>

      <h1 class="text-3xl font-semibold tracking-tight text-primary mb-2" style="font-family: 'Crimson Pro', Georgia, serif;">
        {privacyContent.title}
      </h1>
      <p class="text-xs text-muted-foreground mb-8">Effective Date: {privacyContent.effectiveDate}</p>

      <div class="prose max-w-none text-base text-foreground/80 leading-relaxed space-y-6">
        <p>{privacyContent.content}</p>
      </div>
    </main>

</Layout>