---
import {
  Shield,
  Mail,
  Calendar,
  Heart,
  Users,
  Phone
} from '@lucide/astro';
import '../styles/global.css';
import content from '../data/homepage.json';

// Assets pathing mapping
const headshotImage = "/imports/t-jones-lg.png";
const signatureImage = "/imports/t-jones-88.png";
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tiffany Jones · Life Insurance Specialist</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased" style="font-family: 'DM Sans', system-ui, sans-serif;">

    <!-- ── HEADER ── -->
    <header id="main-header" class="sticky top-0 z-50 transition-all duration-300 bg-transparent">
      <div class="max-w-6xl mx-auto px-6 sm:px-10 py-4 flex items-center justify-between">
        <span class="text-xl font-semibold tracking-tight text-primary" style="font-family: 'Crimson Pro', Georgia, serif;">
          Tiffany Jones
        </span>
        <a href="#contact" class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-primary-foreground text-sm font-medium rounded-[10px] shadow-sm hover:shadow-md hover:bg-primary/90 transition-all duration-200">
          <Mail class="w-4 h-4" />
          Get in Touch
        </a>
      </div>
    </header>

    <!-- ── HERO ── -->
    <section class="max-w-6xl mx-auto px-6 sm:px-10 pt-14 pb-20 md:pt-20 md:pb-28">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_1.05fr] gap-12 md:gap-16 items-center">
        <div class="order-2 md:order-1">
          <p class="text-xs font-medium tracking-[0.2em] uppercase text-accent mb-5">
            {content.tagline}
          </p>
          <h1 class="text-[2.6rem] sm:text-5xl md:text-[3rem] lg:text-[3.4rem] leading-[1.14] font-semibold text-primary mb-6" style="font-family: 'Crimson Pro', Georgia, serif;">
            {content.heroTitle}
          </h1>
          <p class="text-base md:text-lg text-muted-foreground leading-[1.8] mb-9 max-w-[46ch]">
            {content.heroBio}
          </p>
          <div class="flex flex-col items-start sm:items-center gap-5">
            <a href="#contact" class="inline-flex items-center gap-3 px-7 py-[1.05rem] bg-accent text-accent-foreground text-base font-semibold rounded-[10px] shadow-[0_4px_16px_rgba(184,101,42,0.28)] hover:shadow-[0_6px_24px_rgba(184,101,42,0.38)] hover:bg-accent/92 transition-all duration-200 group">
              <Calendar class="w-5 h-5 shrink-0" />
              {content.ctaButtonText}
              <span class="group-hover:translate-x-0.5 transition-transform duration-200 text-lg leading-none">→</span>
            </a>
            <p class="text-sm text-muted-foreground">Free · No obligation · 30 min</p>
          </div>
        </div>

        <div class="order-1 md:order-2 flex justify-center md:justify-end">
          <div class="relative">
            <div class="absolute -bottom-4 -right-4 w-full h-full rounded-[22px] bg-secondary/70 border border-border" />
            <div class="relative w-72 h-[22rem] sm:w-80 sm:h-[24rem] md:w-[21rem] md:h-[26rem] rounded-[22px] overflow-hidden shadow-xl border border-border/50 bg-secondary">
              <img src={headshotImage} alt="Tiffany Jones" class="absolute inset-0 w-full h-full object-cover object-top" />
              <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-secondary/30 to-transparent" />
            </div>
            <div class="absolute -left-5 bottom-10 bg-background rounded-[12px] shadow-lg border border-border px-4 py-3 flex items-center gap-3 min-w-[168px]">
              <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                <Shield class="w-4 h-4 text-primary" />
              </div>
              <div>
                <p class="text-xs font-semibold text-primary leading-none mb-0.5">Licensed & Local</p>
                <p class="text-[11px] text-muted-foreground leading-none">Serving Michigan and beyond</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── BIO / PASSION ── -->
    <section class="bg-card border-y border-border py-16 md:py-24">
      <div class="max-w-2xl mx-auto px-6 sm:px-10 text-center">
        <div class="flex items-center justify-center gap-3 mb-8">
          <span class="block w-8 h-px bg-accent/60" />
          <Heart class="w-4 h-4 text-accent/70" />
          <span class="block w-8 h-px bg-accent/60" />
        </div>

        <h2 class="text-3xl md:text-[2.6rem] leading-[1.2] font-semibold text-primary mb-7" style="font-family: 'Crimson Pro', Georgia, serif;">
          {content.bioTitle}
        </h2>

        <p class="text-base md:text-[1.07rem] text-foreground/78 leading-[1.9] mb-5">{content.bioParagraph1}</p>
        <p class="text-base md:text-[1.07rem] text-foreground/78 leading-[1.9] mb-5">{content.bioParagraph2}</p>
        <p class="text-base md:text-[1.07rem] text-foreground/78 leading-[1.9]">{content.bioParagraph3}</p>

        <div class="mt-10 pt-8 border-t border-border flex items-center justify-center gap-4">
          <div class="w-11 h-11 rounded-full overflow-hidden border border-border bg-secondary shrink-0">
            <img src={signatureImage} alt="Tiffany Jones" class="w-full h-full object-cover object-top" />
          </div>
          <div class="text-left">
            <p class="text-sm font-semibold text-primary leading-none mb-1" style="font-family: 'Crimson Pro', Georgia, serif;">Tiffany Jones</p>
            <p class="text-xs text-muted-foreground">Life Insurance Specialist · Serving Michigan and beyond</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── TRUST BAR ── -->
    <section class="max-w-5xl mx-auto px-6 sm:px-10 py-14 md:py-20">
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-border">
        <div class="flex flex-col items-center text-center px-8 py-10 md:py-2 group">
          <div class="w-11 h-11 rounded-full bg-primary/8 flex items-center justify-center mb-5">
            <Calendar class="w-5 h-5 text-primary" />
          </div>
          <p class="text-3xl md:text-[2rem] font-semibold text-primary leading-none" style="font-family: 'Crimson Pro', Georgia, serif;">100% Free</p>
          <p class="text-lg font-medium text-accent mb-3 mt-0.5" style="font-family: 'Crimson Pro', Georgia, serif;">Consultations</p>
          <p class="text-sm text-muted-foreground leading-relaxed max-w-[22ch]">Every conversation, every time. No retainer, no surprise invoice.</p>
        </div>
        <div class="flex flex-col items-center text-center px-8 py-10 md:py-2 group">
          <div class="w-11 h-11 rounded-full bg-primary/8 flex items-center justify-center mb-5">
            <Users class="w-5 h-5 text-primary" />
          </div>
          <p class="text-3xl md:text-[2rem] font-semibold text-primary leading-none" style="font-family: 'Crimson Pro', Georgia, serif;">Community</p>
          <p class="text-lg font-medium text-accent mb-3 mt-0.5" style="font-family: 'Crimson Pro', Georgia, serif;">Focused</p>
          <p class="text-sm text-muted-foreground leading-relaxed max-w-[22ch]">Born here. Still here. Invested in the people on your street.</p>
        </div>
        <div class="flex flex-col items-center text-center px-8 py-10 md:py-2 group">
          <div class="w-11 h-11 rounded-full bg-primary/8 flex items-center justify-center mb-5">
            <Shield class="w-5 h-5 text-primary" />
          </div>
          <p class="text-3xl md:text-[2rem] font-semibold text-primary leading-none" style="font-family: 'Crimson Pro', Georgia, serif;">Zero</p>
          <p class="text-lg font-medium text-accent mb-3 mt-0.5" style="font-family: 'Crimson Pro', Georgia, serif;">High-Pressure Sales</p>
          <p class="text-sm text-muted-foreground leading-relaxed max-w-[22ch]">Learn at your own pace. Decide entirely on your own terms.</p>
        </div>
      </div>
    </section>

    <!-- ── CONTACT CTA ── -->
    <section id="contact" class="bg-primary py-16 md:py-24">
      <div class="max-w-xl mx-auto px-6 sm:px-10 text-center">
        <h2 class="text-3xl md:text-[2.6rem] leading-[1.18] font-semibold text-primary-foreground mb-5" style="font-family: 'Crimson Pro', Georgia, serif;">
          {content.ctaSectionTitle}
        </h2>
        <p class="text-primary-foreground/65 text-base md:text-lg leading-[1.75] mb-10">
          {content.ctaSectionBody}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={content.ctaScheduleLink} class="inline-flex items-center justify-center gap-2.5 px-7 py-4 bg-accent text-accent-foreground text-base font-semibold rounded-[10px] shadow-[0_4px_20px_rgba(184,101,42,0.38)] hover:shadow-[0_6px_28px_rgba(184,101,42,0.5)] hover:bg-accent/90 transition-all duration-200">
            <Calendar class="w-5 h-5" />
            {content.ctaButtonText}
          </a>
          <a href={content.ctaTelLink} class="inline-flex items-center justify-center gap-2.5 px-7 py-4 border border-primary-foreground/28 text-primary-foreground text-base font-medium rounded-[10px] hover:bg-primary-foreground/10 transition-all duration-200">
            <Phone class="w-5 h-5" />
            {content.ctaTelText}
          </a>
        </div>
      </div>
    </section>

    <!-- ── FOOTER ── -->
    <footer class="bg-background border-t border-border">
      <div class="max-w-6xl mx-auto px-6 sm:px-10 py-8 flex flex-col md:flex-row items-center justify-between gap-6 text-sm text-muted-foreground">
        <p>© {new Date().getFullYear()} Tiffany Jones · Life Insurance Specialist. All rights reserved.</p>
        <div class="flex items-center gap-6">
          <a href="/privacy-policy" class="hover:text-foreground transition-colors duration-150">Privacy Policy</a>
        </div>
      </div>
    </footer>

    <!-- Native Scroll Script Overlay -->
    <script>
      const header = document.getElementById('main-header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 24) {
          header?.classList.remove('bg-transparent');
          header?.classList.add('bg-background/96', 'backdrop-blur-sm', 'shadow-sm', 'border-b', 'border-border');
        } else {
          header?.classList.add('bg-transparent');
          header?.classList.remove('bg-background/96', 'backdrop-blur-sm', 'shadow-sm', 'border-b', 'border-border');
        }
      }, { passive: true });
    </script>
  </body>
</html>